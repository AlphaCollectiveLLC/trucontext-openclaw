{
  "id": "trucontext-openclaw",
  "name": "TruContext Memory",
  "description": "Persistent knowledge graph memory for all OpenClaw agents, powered by TruContext",
  "kind": "memory",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "tcApiBaseUrl": {
        "type": "string",
        "description": "TruContext API base URL",
        "default": "https://api.trucontext.ai"
      },
      "cronSchedule": {
        "type": "string",
        "description": "Cron schedule for daily sync (default: 3am)",
        "default": "0 3 * * *"
      },
      "memoryDays": {
        "type": "number",
        "description": "Days of memory files to harvest on provision",
        "default": 7
      },
      "webhookPath": {
        "type": "string",
        "description": "HTTP route path for TC webhooks",
        "default": "/trucontext/webhook"
      }
    }
  }
}
